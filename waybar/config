{
    "layer": "overlay",
    "position": "bottom",
    "height": 0,
    "spacing": 2,
    "mode": "hide",
    // "output": "HDMI-A-1",
    "margin-top": 0,
    "margin-bottom": 2,
    "modules-left": [
        "custom/exit",
        "hyprland/workspaces",
        "hyprland/mode"
    ],
    "modules-center": [
        "custom/media",
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "network",
        "battery",
        "pulseaudio"
    ],
    // Power Menu
    "custom/exit": {
        "format": "",
        "tooltip-format": "Powermenu",
        "on-click": "wlogout -b 4",
        "tooltip": false
    },
    "custom/media": {
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "blah",
            "default": "🎜"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py",
        "on-click": "playerctl --player=spotify play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "format": "{}"
    },
    "clock": {
        "format": "{:%A, %B %d, %Y | %I:%M %p}",
        "tooltip-format": "{:%A, %B %d, %Y | %H:%M}"
    },
    "cpu": {
        "format": " {usage}%",
        "interval": 5
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                " ",
                " "
            ]
        },
        "on-click": "pavucontrol"
    },
    "memory": {
        "format": " {used:0.1f}G/{total:0.1f}G",
        "interval": 5
    },
    // Workspaces
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": true,
        "all-outputs": false,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "HDMI-A-1": [
                1,
                2,
                3,
                4,
                5
            ],
            "DP-2": [
                6,
                7,
                8,
                9,
                10
            ]
        }
    },
    "network": {
        "format-wifi": " {essid} ({signalStrength}%)",
        "format-ethernet": " {ifname}",
        "format-disconnected": " Disconnected",
        "interval": 5
    }
}